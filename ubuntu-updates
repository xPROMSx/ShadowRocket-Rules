#!/usr/bin/env bash
set -Eeuo pipefail

export DEBIAN_FRONTEND=noninteractive

APT_DAILY_TIME="${APT_DAILY_TIME:-02:30:00}"
APT_UPGRADE_TIME="${APT_UPGRADE_TIME:-02:50:00}"
AUTO_REBOOT_TIME="${AUTO_REBOOT_TIME:-04:22}"

F50="/etc/apt/apt.conf.d/50unattended-upgrades"
F20="/etc/apt/apt.conf.d/20auto-upgrades"
BACKUP_DIR="/root/apt-conf-backups"
STAMP="$(date +%F-%H%M%S)"

OD1_DIR="/etc/systemd/system/apt-daily.timer.d"
OD2_DIR="/etc/systemd/system/apt-daily-upgrade.timer.d"
OD1="${OD1_DIR}/override.conf"
OD2="${OD2_DIR}/override.conf"

B50="${BACKUP_DIR}/50unattended-upgrades.${STAMP}.bak"
B20="${BACKUP_DIR}/20auto-upgrades.${STAMP}.bak"
BOD1="${BACKUP_DIR}/apt-daily.timer.override.${STAMP}.bak"
BOD2="${BACKUP_DIR}/apt-daily-upgrade.timer.override.${STAMP}.bak"

HAD_F20=0
HAD_OD1=0
HAD_OD2=0
DRYLOG_PATH=""
SYSTEM_TZ=""

COLOR_RED=$'\033[31m'
COLOR_GREEN=$'\033[32m'
COLOR_YELLOW=$'\033[33m'
COLOR_BLUE=$'\033[34m'
COLOR_RESET=$'\033[0m'

msg()  { echo "${COLOR_BLUE}==>${COLOR_RESET} $*"; }
ok()   { echo "${COLOR_GREEN}[OK]${COLOR_RESET} $*"; }
warn() { echo "${COLOR_YELLOW}[WARN]${COLOR_RESET} $*"; }
fail() { echo "${COLOR_RED}[FAIL]${COLOR_RESET} $*" >&2; }

require_root() {
  if [[ "${EUID:-0}" -ne 0 ]]; then
    fail "Запустите от root: sudo bash /tmp/ubuntu-updates"
    exit 1
  fi
}

have() {
  command -v "$1" >/dev/null 2>&1
}

file_has_active_line() {
  local file="$1"
  local regex="$2"
  grep -Eq "$regex" "$file"
}

apt_effective_equals() {
  local key="$1"
  local value="$2"
  apt-config dump "$key" 2>/dev/null | grep -Fq "${key} \"${value}\";"
}

timer_override_ok() {
  local file="$1"
  local time_value="$2"
  [[ -f "$file" ]] || return 1
  grep -Fqx '[Timer]' "$file" || return 1
  grep -Fqx 'OnCalendar=' "$file" || return 1
  grep -Fqx "OnCalendar=*-*-* ${time_value}" "$file" || return 1
  grep -Fqx 'RandomizedDelaySec=0' "$file" || return 1
  grep -Fqx 'AccuracySec=1s' "$file" || return 1
}

capture_system_tz() {
  SYSTEM_TZ="$(timedatectl show -p Timezone --value 2>/dev/null || true)"
  if [[ -z "$SYSTEM_TZ" && -r /etc/timezone ]]; then
    SYSTEM_TZ="$(cat /etc/timezone 2>/dev/null || true)"
  fi
  if [[ -z "$SYSTEM_TZ" ]]; then
    SYSTEM_TZ="$(date +%Z)"
  fi
}

cleanup_legacy_noise() {
  rm -f /etc/apt/apt.conf.d/20auto-upgrades.bak.* \
        /etc/apt/apt.conf.d/50unattended-upgrades.bak.* || true
}

ensure_packages() {
  local missing=()

  dpkg -s unattended-upgrades >/dev/null 2>&1 || missing+=(unattended-upgrades)
  dpkg -s python3 >/dev/null 2>&1 || missing+=(python3)

  if ((${#missing[@]} > 0)); then
    msg "Ставлю недостающие пакеты: ${missing[*]}"
    apt-get update -y
    apt-get install -y "${missing[@]}"
  fi

  have apt-config || { fail "Не найдена команда apt-config"; exit 1; }
  have systemctl || { fail "Не найдена команда systemctl"; exit 1; }
  have unattended-upgrade || { fail "Не найдена команда unattended-upgrade"; exit 1; }
}

backup_files() {
  mkdir -p "$BACKUP_DIR"

  [[ -f "$F50" ]] || {
    fail "Не найден файл $F50"
    exit 1
  }

  cp -a "$F50" "$B50"

  if [[ -f "$F20" ]]; then
    HAD_F20=1
    cp -a "$F20" "$B20"
  fi

  if [[ -f "$OD1" ]]; then
    HAD_OD1=1
    cp -a "$OD1" "$BOD1"
  fi

  if [[ -f "$OD2" ]]; then
    HAD_OD2=1
    cp -a "$OD2" "$BOD2"
  fi
}

restore_all() {
  warn "Откатываю изменения к backup..."

  [[ -f "$B50" ]] && cp -af "$B50" "$F50"

  if [[ "$HAD_F20" -eq 1 && -f "$B20" ]]; then
    cp -af "$B20" "$F20"
  else
    rm -f "$F20"
  fi

  if [[ "$HAD_OD1" -eq 1 && -f "$BOD1" ]]; then
    mkdir -p "$OD1_DIR"
    cp -af "$BOD1" "$OD1"
  else
    rm -f "$OD1"
    rmdir --ignore-fail-on-non-empty "$OD1_DIR" 2>/dev/null || true
  fi

  if [[ "$HAD_OD2" -eq 1 && -f "$BOD2" ]]; then
    mkdir -p "$OD2_DIR"
    cp -af "$BOD2" "$OD2"
  else
    rm -f "$OD2"
    rmdir --ignore-fail-on-non-empty "$OD2_DIR" 2>/dev/null || true
  fi

  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl restart apt-daily.timer apt-daily-upgrade.timer >/dev/null 2>&1 || true
}

patch_configs() {
  python3 - "$F50" "$F20" "$AUTO_REBOOT_TIME" <<'PY'
from pathlib import Path
import re
import sys

f50 = Path(sys.argv[1])
f20 = Path(sys.argv[2])
auto_reboot_time = sys.argv[3]

t50 = f50.read_text(encoding="utf-8")

def set_scalar(text: str, key: str, value: str) -> str:
    pat = re.compile(rf'(?m)^[ \t]*(?://\s*)?{re.escape(key)}\s+"[^"\n]*";[ \t]*$')
    text = pat.sub('', text)
    text = re.sub(r'\n{3,}', '\n\n', text).rstrip('\n') + '\n'
    text += f'{key} "{value}";\n'
    return text

m = re.search(r'(?ms)(Unattended-Upgrade::Allowed-Origins\s*\{)(.*?)(^\s*\};)', t50)
if not m:
    raise SystemExit("Не найден блок Unattended-Upgrade::Allowed-Origins")

head, body, tail = m.group(1), m.group(2), m.group(3)

updates_line_regex = re.compile(
    r'(?m)^[ \t]*(?://\s*)?("\$\{distro_id\}:\$\{distro_codename\}-updates";)[ \t]*$'
)

if updates_line_regex.search(body):
    body = updates_line_regex.sub(r'        \1', body)
else:
    body = body.rstrip('\n') + '\n        "${distro_id}:${distro_codename}-updates";\n'

t50 = t50[:m.start()] + head + body + tail + t50[m.end():]

for key, value in [
    ('Unattended-Upgrade::Remove-Unused-Kernel-Packages', 'true'),
    ('Unattended-Upgrade::Remove-New-Unused-Dependencies', 'true'),
    ('Unattended-Upgrade::Automatic-Reboot', 'true'),
    ('Unattended-Upgrade::Automatic-Reboot-Time', auto_reboot_time),
]:
    t50 = set_scalar(t50, key, value)

f50.write_text(t50, encoding='utf-8')

if f20.exists():
    t20 = f20.read_text(encoding='utf-8')
else:
    t20 = ''

for key, value in [
    ('APT::Periodic::Update-Package-Lists', '1'),
    ('APT::Periodic::Unattended-Upgrade', '1'),
]:
    pat = re.compile(rf'(?m)^[ \t]*(?://\s*)?{re.escape(key)}\s+"[^"\n]*";[ \t]*$')
    t20 = pat.sub('', t20)
    t20 = re.sub(r'\n{3,}', '\n\n', t20).rstrip('\n') + '\n'
    t20 += f'{key} "{value}";\n'

f20.write_text(t20, encoding='utf-8')
PY
}

apply_timer_overrides() {
  mkdir -p "$OD1_DIR" "$OD2_DIR"

  cat > "$OD1" <<EOF
[Timer]
OnCalendar=
OnCalendar=*-*-* ${APT_DAILY_TIME}
RandomizedDelaySec=0
AccuracySec=1s
EOF

  cat > "$OD2" <<EOF
[Timer]
OnCalendar=
OnCalendar=*-*-* ${APT_UPGRADE_TIME}
RandomizedDelaySec=0
AccuracySec=1s
EOF

  if ! systemctl daemon-reload; then
    fail "Не удалось выполнить systemctl daemon-reload"
    restore_all
    exit 1
  fi
}

validate_config() {
  if apt-config dump >/dev/null 2>&1; then
    ok "Синтаксис APT-конфига: OK"
  else
    fail "Ошибка синтаксиса APT-конфига"
    restore_all
    exit 1
  fi
}

ensure_timers() {
  systemctl unmask apt-daily.timer apt-daily-upgrade.timer >/dev/null 2>&1 || true
  systemctl unmask apt-daily.service apt-daily-upgrade.service >/dev/null 2>&1 || true

  systemctl enable apt-daily.timer apt-daily-upgrade.timer >/dev/null
  systemctl restart apt-daily.timer apt-daily-upgrade.timer >/dev/null
}

run_dry_run() {
  local drylog
  drylog="$(mktemp /tmp/uu-dryrun.XXXXXX.log)"

  msg "Тест unattended-upgrade --dry-run..."
  if unattended-upgrade -v --dry-run >"$drylog" 2>&1; then
    ok "Dry-run: OK"
  else
    warn "Dry-run завершился с ненулевым кодом. Сохранил лог: $drylog"
  fi

  echo
  sed -n '1,120p' "$drylog" || true
  echo

  DRYLOG_PATH="$drylog"
}

show_timers() {
  echo
  msg "Проверка systemd timers..."
  systemctl is-enabled apt-daily.timer apt-daily-upgrade.timer || true
  systemctl --no-pager --full status apt-daily.timer apt-daily-upgrade.timer | sed -n '1,80p' || true
}

show_pro_status() {
  echo
  msg "Проверка Ubuntu Pro..."
  if have pro; then
    pro status || true
    echo
    pro security-status || true
    echo
    if have canonical-livepatch; then
      canonical-livepatch status || true
    fi
  else
    warn "Команда 'pro' не найдена"
  fi
}

print_effective_config() {
  echo
  msg "Итоговые параметры в файлах конфигурации:"
  grep -nE 'Remove-Unused-Kernel-Packages|Remove-New-Unused-Dependencies|Automatic-Reboot|Automatic-Reboot-Time' "$F50" || true
  grep -nE 'APT::Periodic::Update-Package-Lists|APT::Periodic::Unattended-Upgrade' "$F20" || true
  grep -nE '^[[:space:]]*"\$\{distro_id\}:\$\{distro_codename\}-updates";' "$F50" || true
}

summary() {
  local status="OK"
  local notes=()
  local next_daily=""
  local next_upgrade=""
  local pro_present="no"

  next_daily="$(systemctl show -p NextElapseUSecRealtime --value apt-daily.timer 2>/dev/null || true)"
  next_upgrade="$(systemctl show -p NextElapseUSecRealtime --value apt-daily-upgrade.timer 2>/dev/null || true)"

  if ! dpkg -s unattended-upgrades >/dev/null 2>&1; then
    status="FAIL"
    notes+=("Пакет unattended-upgrades не установлен")
  fi

  if ! apt-config dump >/dev/null 2>&1; then
    status="FAIL"
    notes+=("APT config syntax is broken")
  fi

  if ! apt_effective_equals 'APT::Periodic::Update-Package-Lists' '1'; then
    status="FAIL"
    notes+=("APT::Periodic::Update-Package-Lists != 1")
  fi

  if ! apt_effective_equals 'APT::Periodic::Unattended-Upgrade' '1'; then
    status="FAIL"
    notes+=("APT::Periodic::Unattended-Upgrade != 1")
  fi

  if ! file_has_active_line "$F50" '^[[:space:]]*Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";[[:space:]]*$'; then
    status="FAIL"
    notes+=("Remove-Unused-Kernel-Packages != true")
  fi

  if ! file_has_active_line "$F50" '^[[:space:]]*Unattended-Upgrade::Remove-New-Unused-Dependencies "true";[[:space:]]*$'; then
    status="FAIL"
    notes+=("Remove-New-Unused-Dependencies != true")
  fi

  if ! file_has_active_line "$F50" '^[[:space:]]*Unattended-Upgrade::Automatic-Reboot "true";[[:space:]]*$'; then
    status="FAIL"
    notes+=("Automatic-Reboot != true")
  fi

  if ! file_has_active_line "$F50" "^[[:space:]]*Unattended-Upgrade::Automatic-Reboot-Time \\\"${AUTO_REBOOT_TIME}\\\";[[:space:]]*$"; then
    status="FAIL"
    notes+=("Automatic-Reboot-Time != ${AUTO_REBOOT_TIME}")
  fi

  if ! file_has_active_line "$F50" '^[[:space:]]*"\$\{distro_id\}:\$\{distro_codename\}-updates";[[:space:]]*$'; then
    status="FAIL"
    notes+=("-updates origin is not enabled")
  fi

  if ! timer_override_ok "$OD1" "$APT_DAILY_TIME"; then
    status="FAIL"
    notes+=("apt-daily.timer override is missing or wrong")
  fi

  if ! timer_override_ok "$OD2" "$APT_UPGRADE_TIME"; then
    status="FAIL"
    notes+=("apt-daily-upgrade.timer override is missing or wrong")
  fi

  if ! systemctl is-enabled apt-daily.timer >/dev/null 2>&1; then
    status="FAIL"
    notes+=("apt-daily.timer is not enabled")
  fi

  if ! systemctl is-enabled apt-daily-upgrade.timer >/dev/null 2>&1; then
    status="FAIL"
    notes+=("apt-daily-upgrade.timer is not enabled")
  fi

  if ! systemctl is-active apt-daily.timer >/dev/null 2>&1; then
    status="FAIL"
    notes+=("apt-daily.timer is not active")
  fi

  if ! systemctl is-active apt-daily-upgrade.timer >/dev/null 2>&1; then
    status="FAIL"
    notes+=("apt-daily-upgrade.timer is not active")
  fi

  if [[ -n "$DRYLOG_PATH" ]]; then
    if grep -qE 'All upgrades installed|No packages found that can be upgraded unattended|Packages that will be upgraded:' "$DRYLOG_PATH"; then
      :
    else
      [[ "$status" == "OK" ]] && status="WARN"
      notes+=("Dry-run output should be reviewed")
    fi
  fi

  if have pro; then
    pro_present="yes"
  fi

  echo
  echo "========== SUMMARY =========="
  echo "System timezone            : ${SYSTEM_TZ}"
  echo "APT daily lists update     : $(apt_effective_equals 'APT::Periodic::Update-Package-Lists' '1' && echo ON || echo OFF)"
  echo "APT unattended upgrade     : $(apt_effective_equals 'APT::Periodic::Unattended-Upgrade' '1' && echo ON || echo OFF)"
  echo "Allow noble-updates        : $(file_has_active_line "$F50" '^[[:space:]]*"\$\{distro_id\}:\$\{distro_codename\}-updates";[[:space:]]*$' && echo ON || echo OFF)"
  echo "Kernel cleanup             : $(file_has_active_line "$F50" '^[[:space:]]*Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";[[:space:]]*$' && echo ON || echo OFF)"
  echo "New unused deps cleanup    : $(file_has_active_line "$F50" '^[[:space:]]*Unattended-Upgrade::Remove-New-Unused-Dependencies "true";[[:space:]]*$' && echo ON || echo OFF)"
  echo "Automatic reboot           : $(file_has_active_line "$F50" '^[[:space:]]*Unattended-Upgrade::Automatic-Reboot "true";[[:space:]]*$' && echo ON || echo OFF)"
  echo "Automatic reboot time      : ${AUTO_REBOOT_TIME}"
  echo "apt-daily time             : ${APT_DAILY_TIME}"
  echo "apt-daily-upgrade time     : ${APT_UPGRADE_TIME}"
  echo "apt-daily.timer            : $(systemctl is-enabled apt-daily.timer >/dev/null 2>&1 && echo enabled || echo disabled) / $(systemctl is-active apt-daily.timer >/dev/null 2>&1 && echo active || echo inactive)"
  echo "apt-daily-upgrade.timer    : $(systemctl is-enabled apt-daily-upgrade.timer >/dev/null 2>&1 && echo enabled || echo disabled) / $(systemctl is-active apt-daily-upgrade.timer >/dev/null 2>&1 && echo active || echo inactive)"
  echo "Next apt-daily run         : ${next_daily:-unknown}"
  echo "Next apt-daily-upgrade run : ${next_upgrade:-unknown}"
  echo "Ubuntu Pro client present  : ${pro_present}"
  echo "Logs dir                   : /var/log/unattended-upgrades"
  echo "Backups dir                : ${BACKUP_DIR}"

  echo
  if [[ "$status" == "OK" ]]; then
    ok "STATUS: OK"
  elif [[ "$status" == "WARN" ]]; then
    warn "STATUS: WARN"
  else
    fail "STATUS: FAIL"
  fi

  if ((${#notes[@]} > 0)); then
    echo
    echo "Пояснения:"
    for note in "${notes[@]}"; do
      echo "- $note"
    done
  fi

  echo
  echo "Backup 50: $B50"
  if [[ "$HAD_F20" -eq 1 ]]; then
    echo "Backup 20: $B20"
  else
    echo "Backup 20: not needed (file was created from scratch)"
  fi
  if [[ "$HAD_OD1" -eq 1 ]]; then
    echo "Backup apt-daily override: $BOD1"
  fi
  if [[ "$HAD_OD2" -eq 1 ]]; then
    echo "Backup apt-daily-upgrade override: $BOD2"
  fi
}

main() {
  require_root
  capture_system_tz
  cleanup_legacy_noise
  ensure_packages
  backup_files
  patch_configs
  apply_timer_overrides
  validate_config
  ensure_timers
  run_dry_run
  show_timers
  show_pro_status
  print_effective_config
  summary
}

main "$@"
